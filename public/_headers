# Cloudflare Workers static assets custom headers
# https://developers.cloudflare.com/workers/static-assets/headers/

# Hashed CSS — immutable long cache
/_assets/app-*.css
  Cache-Control: public, max-age=31536000, immutable

# Island/game JS/WASM — stable filenames, so revalidate on every load to pick up
# redeploys immediately (the ETag makes this a cheap 304 when unchanged).
/_assets/*.js
  Cache-Control: public, max-age=0, must-revalidate
/_assets/*.wasm
  Cache-Control: public, max-age=0, must-revalidate

# Self-hosted fonts — immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images
/images/*
  Cache-Control: public, max-age=86400

# RSS and sitemap — short cache
/feed.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/rss+xml; charset=utf-8
/sitemap.xml
  Cache-Control: public, max-age=3600

# Security headers for all pages
# script-src adds 'wasm-unsafe-eval' for the Leptos WASM island.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
